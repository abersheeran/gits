{
  "name": "gits",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run db:migrate:local && wrangler dev --local --env-file .env",
    "dev:api": "npm run dev",
    "dev:web": "npm --prefix web run dev",
    "build": "npm run build:web",
    "build:web": "npm --prefix web run build",
    "deploy": "npm run build:web && wrangler deploy --minify --keep-vars",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "d1:create:remote": "wrangler d1 create gits",
    "db:migrate": "wrangler d1 migrations apply DB --remote",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "secret:prod:jwt": "wrangler secret put JWT_SECRET",
    "secret:prod": "npm run secret:prod:jwt",
    "secret:dev:set": "node scripts/set-local-secret.mjs",
    "secret:dev:jwt": "npm run secret:dev:set -- JWT_SECRET .env",
    "secret:dev": "npm run secret:dev:jwt"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@aws-sdk/client-s3": "^3.888.0",
    "@cloudflare/containers": "^0.0.25",
    "bcryptjs": "^2.4.3",
    "diff": "^8.0.3",
    "hono": "^4.12.3",
    "isomorphic-git": "^1.35.1",
    "jose": "^5.10.0",
    "memfs": "^4.51.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^25.3.3",
    "shadcn": "^3.8.5",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.69.0"
  }
}
